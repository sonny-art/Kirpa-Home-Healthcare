# ─────────────────────────────────────────────────────────────────────────────
# Email delivery for website forms (Request a Service, Careers, Contact)
# All form submissions are emailed to the address below.
# ─────────────────────────────────────────────────────────────────────────────

# Where every form submission is delivered.
CONTACT_TO_EMAIL=kirpahhc@gmail.com

# Resend API key — get a free one at https://resend.com (create the account
# using kirpahhc@gmail.com so test emails deliver to that inbox immediately).
# In Vercel: Project → Settings → Environment Variables → add RESEND_API_KEY.
RESEND_API_KEY=

# The "From" address Resend sends with.
# - Quick start (no domain needed): onboarding@resend.dev
#   (only delivers to the email used to create the Resend account)
# - Production: verify your domain in Resend and use e.g. website@kirpahomehealthcare.org
CONTACT_FROM_EMAIL=Kirpa Home Health Care <onboarding@resend.dev>

# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://kirpahomehealthcare.org
